# .env Example:

# Backend
JWT_SECRET="very_secret_key_that_has_no_flaws" # In production, use a strong, random secret key and keep it secure.
DEFAULT_ADMIN_USERNAME=root # Change as needed, can always change later via API or webapp. 
DEFAULT_ADMIN_PASSWORD=root # In production use a stronger password
DEFAULT_ADMIN_EMAIL="root@example.com"
ALLOWED_ORIGINS="http://localhost:5173,http://0.0.0.0:5173,http://127.0.0.1:5173,http://frontend:5173,*" # Change in prod to only allow specific urls 

# Database:
POSTGRES_USER=postgres
POSTGRES_PASSWORD=gloorp
POSTGRES_DB=food_db
DATABASE_URL=postgresql://postgres:gloorp@database:5432/food_db # Fill in to match the user, password, the db name listed above.

# Valkey Cache
VALKEY_URL="valkey://localhost:6379"


# Frontend
VITE_API_BASE_URL="http://127.0.0.1:8000" # Where the frontend should send API requests.
